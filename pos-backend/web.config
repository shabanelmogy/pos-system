<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="node"
                  arguments="app.js"
                  startupTimeLimit="300"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\node.log">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NODE_ENV" value="production" />
        <!-- Note: Use Adam%402008 for Adam@2008 in the connection string -->
        <environmentVariable name="DATABASE_URL" value="postgresql://neondb_owner:npg_NH9hvBlb1iRj@ep-hidden-hill-api2dpp1-pooler.c-7.us-east-1.aws.neon.tech/pos-system?sslmode=require" />
        <environmentVariable name="JWT_SECRET" value="9fK2xL#vQ8mP@7sN!4dR$2wZyT6uHcA1jXoE5bLm" />
        <environmentVariable name="CORS_ORIGIN" value="https://pos-system-8779f.web.app,https://localhost:5173" />
        <environmentVariable name="RAZORPAY_KEY_ID" value="your_razorpay_key_id" />
        <environmentVariable name="RAZORPAY_KEY_SECRET" value="your_razorpay_key_secret" />
        <environmentVariable name="RAZORPAY_WEBHOOK_SECRET" value="your_razorpay_webhook_secret" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>

